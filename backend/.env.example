APP_HOST=0.0.0.0
APP_PORT=3000
LOG_LEVEL=INFO
STORAGE_UPLOAD_DIR=backend/storage/uploads
STORAGE_ORPHAN_MAX_AGE_HOURS=24

# 影像二进制存储后端：local（默认，落本地盘 storage/imagery/，单机够用）
# 或 minio（对象存储，多实例/可迁移）。切 minio 需 `docker compose up -d db minio`
# 并 `pip install -e .[minio]`；owner 鉴权统一走 DB（imagery 表），不依赖本地 metadata.json。
STORAGE_BACKEND=local
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=agent_rs
MINIO_SECRET_KEY=agent_rs_local
MINIO_BUCKET=agent-rs
MINIO_SECURE=false

AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_DEFAULT_MODEL=gpt-4.1-mini
AI_THINKING_BUDGET=512
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2
AI_TRUST_ENV_PROXY=false
AI_MAX_HISTORY_MESSAGES=24
AI_MAX_CONTEXT_CHARS=24000
AI_CONTEXT_MAX_TOTAL_CHARS=24000
AI_CONTEXT_MAX_RECENT_CHARS=16000
AI_CONTEXT_MAX_RECENT_MESSAGES=24
AI_CONTEXT_MAX_USER_EXTRA_CHARS=2000
AI_CONTEXT_MAX_SUMMARY_CHARS=3000
AI_CONTEXT_MAX_MEMORY_CHARS=3000
AI_CONTEXT_MAX_RAG_CHARS=6000
AI_CONTEXT_MAX_TOOL_CHARS=6000
AI_CONTEXT_MAX_PRIOR_RESULTS_CHARS=2000
AI_CONTEXT_MAX_IMAGERY_CHARS=2000
AI_CONTEXT_MAX_DOCUMENT_CHARS=3000
AI_CONTEXT_MAX_GEO_CHARS=2000
AI_PROMPT_PROFILE=agent_rs_core_v1
AI_PROMPT_ENABLE_DYNAMIC_MODULES=true
AI_PROMPT_INCLUDE_REASONING_BOUNDARY=true
AI_PROMPT_MAX_CORE_CHARS=8000
AI_PROMPT_MAX_OPTIONAL_CHARS=3000
AI_SYSTEM_PROMPT_LANGUAGE=zh-CN
AI_ASSISTANT_NAME=Agent-RS

# 允许前端配置页填写 base_url/api_key：env 未填 AI_API_KEY 时降级用前端值（本地零配置友好）。
# 公网多用户部署请设 false，锁定服务端密钥、禁止客户端覆盖。
ALLOW_CLIENT_PROVIDER_CONFIG=true
ALLOW_USER_EXTRA_INSTRUCTIONS=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

TAVILY_API_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
# Leave empty to use the resolved chat model for planning. Set only when the provider supports this model.
AGENT_PLANNING_MODEL=
AGENT_DOCUMENT_INVENTORY_LIMIT=100
AGENT_WEB_SEARCH_MAX_CALLS=1
AGENT_WEB_SEARCH_MAX_RESULTS=5
# 联网搜索区域偏好：china=优先国内结果；留空=全球检索（Tavily 默认）
AGENT_WEB_SEARCH_COUNTRY=china
AGENT_WEB_SEARCH_TIMEOUT_SECONDS=15
AGENT_WEB_SEARCH_INPUT_MAX_CHARS=2000
AGENT_WEB_SEARCH_RESULT_MAX_CHARS=6000
AGENT_DECISION_CACHE_TTL_SECONDS=1800
AGENT_DECISION_CACHE_MAX_SIZE=256
AGENT_RESULT_CACHE_TTL_SECONDS=300
AGENT_RESULT_CACHE_MAX_SIZE=64
AGENT_WEB_SEARCH_RERANK_ENABLED=true
AGENT_WEB_SEARCH_RERANK_TOP_N=5

AUTH_ENABLED=true
# 【公网部署必改】会话令牌/邀请码的 HMAC 密钥。务必改成一段长随机串（如 `openssl rand -hex 32`）。
# DATABASE_ENABLED=true 且此值仍为 dev-change-me 时，登录/注册会被后端拒绝（500 AUTH_SECRET_INSECURE）。
AUTH_SECRET_KEY=change-this-to-a-long-random-string
AUTH_SESSION_COOKIE_NAME=agent_rs_session
AUTH_SESSION_DAYS=14
# 【公网部署必改】走 HTTPS 时设 true：cookie 仅经加密连接发送，并启用 HSTS 头。本地 http 开发用 false。
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# 密码策略：最短 10（OWASP 无 MFA 场景建议）、最长 128（防超长串触发 PBKDF2 计算 DoS）。
AUTH_PASSWORD_MIN_LENGTH=10
AUTH_PASSWORD_MAX_LENGTH=128
# 登录失败限流（进程内，单实例 beta 适用）：同一邮箱连续失败达上限后锁定一个窗口，指数退避。
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
# 注册门控：true=必须持有效邀请码才能注册（定向内测默认）。开放注册设 false（不推荐公网）。
INVITE_REQUIRED=true
# 管理员邮箱（逗号分隔）。邮箱∈此列表即管理员，可签发邀请码/管理用户。
# 首个管理员：先 `python -m scripts.admin_bootstrap mint-invite` 铸码，再用这里的邮箱+该码注册。
ADMIN_EMAILS=

# 持久化：本项目仅 PostgreSQL（pgvector），登录/记忆/历史/知识库全部落库。
# 本地开发用 docker compose 起库：`docker compose up -d db`（见仓库根 docker-compose.yml）。
# DATABASE_ENABLED=false 时存储能力整体关闭（写文档/查历史等返回 503），仅用于无库的纯算子调试。
DATABASE_ENABLED=true
DATABASE_URL=postgresql://agent_rs:your_password@127.0.0.1:15432/agent_rs
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
# 测试库地址（pytest PG 集成用例连接；缺省自动派生独立 *_test 库，与应用库物理隔离）。
# 重要：测试用例间靠 TRUNCATE 业务表做隔离，切勿把此值指向应用库（同名会被 conftest 护栏拒绝）。
# 留空 → 自动用 <应用库名>_test（本机即 agent_rs_test），首次跑测试时自动 CREATE。
# 需自定义时才显式填写，且必须与 DATABASE_URL 不同库名。
TEST_DATABASE_URL=postgresql://agent_rs:agent_rs_local@127.0.0.1:15432/agent_rs_test

DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001
DEFAULT_WORKSPACE_ID=00000000-0000-4000-8000-000000000001
DEFAULT_USER_EMAIL=default@local.agent-rs
DEFAULT_USER_NAME=Default User
DEFAULT_WORKSPACE_SLUG=default
DEFAULT_WORKSPACE_NAME=Default Workspace

EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=10
EMBEDDING_BACKGROUND_CONCURRENCY=8

RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_API_KEY=
RERANK_MODEL=gte-rerank-v2
RERANK_TOP_N=5
RAG_CANDIDATE_LIMIT=12
RAG_RRF_K=60
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.7

RS_TOOLS_MCP_USE_DOCKER=true
RS_DETECT_MCP_USE_DOCKER=true
RS_SEGMENT_MCP_USE_DOCKER=true
RS_DOC_MCP_USE_DOCKER=true
# 同时运行的遥感工具容器上限；超出排队等待。防多用户并发打爆宿主机内存。
RS_TOOLS_MAX_CONCURRENT=3
# durable 工具任务队列：持久化工具执行记录 + 重启恢复孤儿任务。
# false=退回纯同步执行、不写 job（与迁移前等价）。正常流量仍同步实时推 SSE，队列只做记录+恢复。
TOOL_JOBS_ENABLED=true
# 恢复 worker 轮询间隔（秒）。
TOOL_JOBS_POLL_INTERVAL_SECONDS=30
# 孤儿判定阈值（秒）：running 心跳超过此值视为被重启打断。取 max(工具timeout)×1.5 覆盖 segment 的 300s。
TOOL_JOBS_STALE_AFTER_SECONDS=450

DOCUMENT_MAX_FILE_BYTES=20971520
DOCUMENT_MAX_PDF_PAGES=200
DOCUMENT_MAX_CHUNKS=50
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNK_MIN_SIZE=200
DOCUMENT_OCR_MAX_PAGES=20
DOCUMENT_OCR_TIMEOUT_SECONDS=120
DOCUMENT_OCR_MIN_CHARS_PER_PAGE=50
DOCUMENT_OCR_LANGUAGES=chi_sim+eng

MEMORY_JUDGE_ENABLED=true
MEMORY_JUDGE_MODEL=
MEMORY_JUDGE_MIN_USER_CHARS=10
MEMORY_RETRIEVAL_LIMIT=5
RAG_RETRIEVAL_LIMIT=5
